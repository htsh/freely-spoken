# ── Provider API keys ─────────────────────────────────────────────────────────
# Set a key for each provider you list in LOOKUP_PROVIDER_ORDER. Providers whose
# keys are unset just fail fast and the chain falls through to the next one.

GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
CEREBRAS_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=

# HuggingFace router — the PAID last-resort backstop (Inference Providers credit).
# Only billed when every free provider above it has failed, so it is near-free in
# practice. HF_MODEL is optional; default is DeepSeek-V4-Flash (sharper selection
# on hard inputs, fewer refusals). openai/gpt-oss-20b:fireworks-ai is a cheaper
# alternative if cost ever matters at the tail.
HF_TOKEN=
HF_MODEL=deepseek-ai/DeepSeek-V4-Flash:fireworks-ai

# Cloudflare Workers AI needs BOTH the account id and an API token scoped to
# Workers AI (a bare API key alone is not enough).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Lookup behavior ───────────────────────────────────────────────────────────
# Shared secret required on the X-Lookup-Client-Secret request header. Leave
# unset to disable the check (e.g. local dev).
LOOKUP_CLIENT_SECRET=

# Ordered, comma-separated provider chain. Valid names: gemini, openrouter,
# groq, cloudflare, cerebras, cohere, together, mistral, nvidia, huggingface. Order by
# what your keys can sustain — see https://github.com/cheahjs/free-llm-api-resources
# for free-tier limits (note Gemini's free tier is only a handful of requests/day).
# huggingface is the paid backstop — keep it LAST so it only spends credit when the
# free tier is exhausted.
LOOKUP_PROVIDER_ORDER=groq,cerebras,mistral,cloudflare,openrouter,cohere,together,nvidia,huggingface

# Providers eligible for per-request rotation. These are shuffled to the front of
# the chain on every request so concurrent load spreads across them (fewer 429s,
# the slow tail gets hit less). Everything else in LOOKUP_PROVIDER_ORDER stays a
# fixed last-resort tail. Set empty to disable rotation (pure static order).
LOOKUP_FAST_TIER=groq,cerebras,mistral

# Per-provider request timeouts in seconds, "name:secs" comma-separated. Cap your
# slow providers low enough that the chain can give up on one and still reach a
# working provider inside the client's overall budget. Unlisted providers use
# LOOKUP_DEFAULT_TIMEOUT.
LOOKUP_PROVIDER_TIMEOUTS=nvidia:15,openrouter:15,cohere:20,cloudflare:15,together:15,huggingface:30
LOOKUP_DEFAULT_TIMEOUT=60

LOOKUP_MAX_RETRIES=3
LOOKUP_MAX_CONCURRENCY=8

# ── Bible API (christian variant only) ────────────────────────────────────────
BIBLE_API_URL=https://bible-api.com
BIBLE_TRANSLATION=web
