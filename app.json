{
  "expo": {
    "name": "Freely Spoken",
    "slug": "mic-check",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "miccheck",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Allow Freely Spoken to use speech recognition to transcribe your recordings.",
        "NSMicrophoneUsageDescription": "Allow Freely Spoken to access your microphone.",
        "NSPhotoLibraryUsageDescription": "Freely Spoken does not use your photo library. This permission description is included because a bundled library references photo library APIs."
      },
      "buildNumber": "4",
      "bundleIdentifier": "com.htsh.miccheck"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F1E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.htsh.miccheck"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#F7F1E8",
          "dark": {
            "backgroundColor": "#F7F1E8"
          }
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Freely Spoken to access your microphone for voice recording."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Freely Spoken to access your microphone.",
          "speechRecognitionPermission": "Allow Freely Spoken to use speech recognition to transcribe your recordings."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9af03ee3-2eae-4f5c-b0fe-60200c3bd29d"
      },
      "lookupApiUrl": "$EXPO_PUBLIC_LOOKUP_API_URL",
      "lookupClientSecret": "$EXPO_PUBLIC_LOOKUP_CLIENT_SECRET",
      "appVariant": "$EXPO_PUBLIC_APP_VARIANT"
    },
    "owner": "arlodog"
  }
}
