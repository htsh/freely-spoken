# Gemini API key for verse lookup (free tier)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter API key — used as fallback when Gemini returns 429
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq API key — another provider option with free tier
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
