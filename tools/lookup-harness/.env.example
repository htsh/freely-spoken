# Gemini API key for verse lookup (free tier)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter API key — used as fallback when Gemini returns 429
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq API key — another provider option with free tier
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Bible API host for fetching canonical verse text (Christian variant).
# Defaults to https://bible-api.com (rate-limited to 15 req / 30s per IP,
# described as a hobby service). Override with your own self-hosted copy.
BIBLE_API_URL=

# Translation id passed as ?translation=. Defaults to 'web' (World English Bible).
# Other options: kjv, asv, bbe, darby, dra, ylt, oeb-us, oeb-cw, webbe.
BIBLE_TRANSLATION=
