{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "christian"
      },
      "ios": {
        "buildConfiguration": "Debug"
      }
    },
    "development-idleashes": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "dhammapada"
      },
      "ios": {
        "buildConfiguration": "Debug"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "christian"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "preview-idleashes": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "dhammapada"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "christian"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production-idleashes": {
      "distribution": "store",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "dhammapada"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {}
    },
    "production-idleashes": {
      "ios": {}
    }
  }
}
